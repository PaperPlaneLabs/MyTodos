{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "my-todos",
  "version": "0.1.34",
  "identifier": "com.pintu.my-todos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "MyTodos",
        "width": 380,
        "height": 800,
        "minWidth": 44,
        "minHeight": 100,
        "resizable": true,
        "center": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ3QjlCNkY1MDM1NjZDOTMKUldTVGJGWUQ5YmE1MTFJVWJUNTNRRUtDaklKRVNsaHlITmY5cXp5NHA4dzVGeFVwdHNqSDYvTDYK",
      "endpoints": [
        "https://github.com/SujithChristopher/MyTodos-releases/releases/latest/download/latest.json"
      ]
    }
  }
}